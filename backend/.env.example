# Server
PORT=3001
FRONTEND_URL=http://localhost:5173

# Supabase — find these in: Project Settings → API
# Use the SERVICE ROLE key (not anon key) — backend only, never expose to frontend
# These same values must also be set in Vercel Environment Variables for the API functions
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Admin API key — used to protect GET /api/waitlist (make this a random string)
ADMIN_KEY=your-random-admin-key

# Email (SMTP) — e.g. Gmail: host=smtp.gmail.com, port=587, secure=false
# For Gmail you need an App Password (not your regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Where to send owner notifications (defaults to SMTP_USER if not set)
OWNER_EMAIL=your-email@gmail.com
